# Server
NODE_ENV=development
PORT=5001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/safespace?retryWrites=true&w=majority

# Redis (optional)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-64-character-random-string-here
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Client
CLIENT_URL=http://localhost:3000
REACT_APP_API_URL=https://your-server.onrender.com/api
REACT_APP_SOCKET_URL=https://your-server.onrender.com


# Render examples
# NODE_ENV=production
# CLIENT_URL=https://your-client.onrender.com
# CORS_ORIGIN=https://your-client.onrender.com
# REACT_APP_API_URL=https://your-server.onrender.com/api
# REACT_APP_SOCKET_URL=https://your-server.onrender.com
